{
  "name": "trafoe-katalog-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-Desktop-App: erstellt per Knopfdruck den TRAFOE Gebrauchtstapler-PDF-Katalog von stapler.trafoe.de.",
  "main": "app/main/index.js",
  "author": {
    "name": "Stefan Heinemann",
    "email": "stefan@heinemann.berlin"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-renderer.mjs",
    "start": "npm run build && electron .",
    "install-browsers": "node scripts/install-browsers.mjs",
    "dist": "npm run build && electron-builder && node scripts/finalize-release.mjs",
    "postinstall": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "de.trafoe.katalogdesktop",
    "productName": "TRAFOE Katalog Generator",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "app/**/*",
      "assets/**/*",
      "VERSION",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "ms-playwright",
        "to": "ms-playwright"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "assets/logos/Trafoe-Logo-small.ico",
      "signAndEditExecutable": false,
      "electronLanguages": [
        "de",
        "en-US"
      ]
    },
    "portable": {
      "requestExecutionLevel": "user",
      "artifactName": "TRAFOE-Katalog-Generator.exe",
      "splashImage": "assets/splash.bmp"
    }
  }
}
