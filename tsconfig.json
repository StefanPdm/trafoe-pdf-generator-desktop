{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "app",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/main"]
}
